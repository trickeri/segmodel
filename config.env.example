# Copy to config.env and edit for machine-specific overrides. All optional.
# segmodel.sh sources this if present.

#SG_HOST=127.0.0.1
#SG_PORT=48470

# Backend is normally read from backend.txt (written by build.sh): cuda | vulkan.
#SG_BACKEND=cuda

# Model override. Default per backend:
#   cuda   → models/birefnet_lite.onnx   (BiRefNet, best quality, arbitrary subjects)
#   vulkan → models/u2net                (loads u2net.param/.bin via ncnn)
#SG_MODEL=$HOME/programming/segmodel/models/birefnet_lite.onnx
